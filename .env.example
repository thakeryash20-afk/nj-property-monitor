OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_WEB_MODEL=gpt-4o-search-preview

# Zillow API integration (optional)
# Quick setup uses a Zillow-compatible RapidAPI endpoint.
# For official Zillow Group datasets, request access via Zillow Group Developers/Bridge.
ZILLOW_API_KEY=your_zillow_api_key_here
ZILLOW_API_URL=https://zillow-com1.p.rapidapi.com/propertyExtendedSearch
ZILLOW_API_HOST=zillow-com1.p.rapidapi.com
# Optional provider switch:
# ZILLOW_PROVIDER=rapidapi
# ZILLOW_PROVIDER=hasdata
# HasData example:
# ZILLOW_API_URL=https://api.hasdata.com/scrape/zillow/listing
# ZILLOW_API_KEY_HEADER=x-api-key
# ZILLOW_AREA_PARAM=keyword
# ZILLOW_AREA_FORMAT={area}, NJ
# ZILLOW_HASDATA_TYPE=forSale
# Optional if your API provider uses different header names:
# ZILLOW_API_KEY_HEADER=x-rapidapi-key
# ZILLOW_API_HOST_HEADER=x-rapidapi-host
# Optional extra query params as JSON:
# ZILLOW_EXTRA_QUERY_JSON={"status_type":"ForSale","sort":"Newest"}
