OPENAI_API_KEY = "your_openai_api_key"
OPENAI_MODEL = "gpt-4.1-mini"
OPENAI_WEB_MODEL = "gpt-4o-search-preview"

ZILLOW_API_KEY = "your_zillow_api_key"
ZILLOW_PROVIDER = "hasdata"
ZILLOW_API_URL = "https://api.hasdata.com/scrape/zillow/listing"
ZILLOW_API_KEY_HEADER = "x-api-key"
ZILLOW_AREA_PARAM = "keyword"
ZILLOW_AREA_FORMAT = "{area}, NJ"
ZILLOW_HASDATA_TYPE = "forSale"
